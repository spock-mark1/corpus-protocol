generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// ─── Corpus (Agent Corporation) ───────────────────────────────────
model Corpus {
  id               String   @id @default(cuid())
  name             String
  category         String   // Marketing, Development, Research, Design
  description      String
  status           String   @default("Active") // Active, Inactive

  // Pulse Token
  hederaTokenId    String?
  pulsePrice       Decimal  @default(0) @db.Decimal(18, 6)
  totalSupply      Int      @default(1000000)

  // Patron Equity Structure
  creatorShare     Int      @default(60)
  investorShare    Int      @default(25)
  treasuryShare    Int      @default(15)

  // Product API
  apiEndpoint      String?
  apiKey           String?  @unique // issued to Local Agent

  // Prime Agent Config
  persona          String?
  targetAudience   String?
  channels         String[] @default([])
  toneVoice        String?

  // Kernel Policy
  approvalThreshold Decimal @default(10) @db.Decimal(18, 2)
  gtmBudget         Decimal @default(200) @db.Decimal(18, 2)

  // Agent Status
  agentOnline      Boolean  @default(false)
  agentLastSeen    DateTime?

  // Wallet
  walletAddress    String?
  creatorAddress   String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  patrons          Patron[]
  activities       Activity[]
  approvals        Approval[]
  revenues         Revenue[]
  commerceServices CommerceService?
  commerceJobs     CommerceJob[]

  @@map("cpp_corpus")
  @@schema("public")
}

// ─── Patron (Shareholder) ─────────────────────────────────────────
model Patron {
  id             String   @id @default(cuid())
  corpusId       String
  walletAddress  String
  role           String   // Creator, Investor, Treasury
  pulseAmount    Int      @default(0)
  share          Decimal  @db.Decimal(5, 2) // percentage

  worldIdHash    String?  // World ID uniqueness

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  corpus         Corpus   @relation(fields: [corpusId], references: [id], onDelete: Cascade)

  @@unique([corpusId, walletAddress])
  @@map("cpp_patrons")
  @@schema("public")
}

// ─── Activity Log ─────────────────────────────────────────────────
model Activity {
  id        String   @id @default(cuid())
  corpusId  String
  type      String   // post, research, reply, commerce, approval
  content   String
  channel   String   // X, LinkedIn, Reddit, x402, Dashboard
  status    String   @default("completed") // completed, pending, failed

  createdAt DateTime @default(now())

  corpus    Corpus   @relation(fields: [corpusId], references: [id], onDelete: Cascade)

  @@index([corpusId, createdAt(sort: Desc)])
  @@map("cpp_activities")
  @@schema("public")
}

// ─── Approval Request ─────────────────────────────────────────────
model Approval {
  id          String   @id @default(cuid())
  corpusId    String
  type        String   // transaction, strategy, policy, channel
  title       String
  description String?
  amount      Decimal? @db.Decimal(18, 6)
  status      String   @default("pending") // pending, approved, rejected

  decidedAt   DateTime?
  decidedBy   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  corpus      Corpus   @relation(fields: [corpusId], references: [id], onDelete: Cascade)

  @@index([corpusId, status])
  @@map("cpp_approvals")
  @@schema("public")
}

// ─── Revenue ──────────────────────────────────────────────────────
model Revenue {
  id        String   @id @default(cuid())
  corpusId  String
  amount    Decimal  @db.Decimal(18, 6)
  currency  String   @default("USDC")
  source    String   // commerce, direct, subscription
  txHash    String?

  createdAt DateTime @default(now())

  corpus    Corpus   @relation(fields: [corpusId], references: [id], onDelete: Cascade)

  @@index([corpusId, createdAt(sort: Desc)])
  @@map("cpp_revenues")
  @@schema("public")
}

// ─── Commerce Service (Storefront) ────────────────────────────────
model CommerceService {
  id            String   @id @default(cuid())
  corpusId      String   @unique
  serviceName   String
  description   String?
  price         Decimal  @db.Decimal(18, 6) // per request
  currency      String   @default("USDC")
  walletAddress String
  chains        String[] @default(["hedera"])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  corpus        Corpus   @relation(fields: [corpusId], references: [id], onDelete: Cascade)

  @@map("cpp_commerce_services")
  @@schema("public")
}

// ─── Commerce Job (x402 Job Queue) ────────────────────────────────
model CommerceJob {
  id             String   @id @default(cuid())
  corpusId       String   // service provider corpus
  requesterCorpusId String
  serviceName    String
  payload        Json?
  result         Json?
  status         String   @default("pending") // pending, processing, completed, failed
  paymentSig     String?
  amount         Decimal  @db.Decimal(18, 6)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  corpus         Corpus   @relation(fields: [corpusId], references: [id], onDelete: Cascade)

  @@index([corpusId, status])
  @@map("cpp_commerce_jobs")
  @@schema("public")
}

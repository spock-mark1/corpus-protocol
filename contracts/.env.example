# ─── Hedera Testnet Account ───────────────────────────────
# Create at https://portal.hedera.com (auto-grants 10,000 testnet HBAR)
# Account ID format: 0.0.xxxxx
# Private key: hex or DER format (from Portal > Accounts > Show keys)

HEDERA_PRIVATE_KEY=0xf2c8d97f31824c56d9f09e124ec31e6b9c7846d13b1275e8ea1edbaa47ff8a68

# ─── Protocol Wallet ──────────────────────────────────────
# Receives 3% launchpad fee on every Corpus Genesis.
# EVM format (0x...). Defaults to deployer address if not set.

CORPUS_PROTOCOL_WALLET=0x0d43d40170b25c41e5a6fdde209978b41d1b8de6

# ─── Post-Deployment (auto-generated) ─────────────────────
# These are printed after running `pnpm deploy:testnet`.
# Copy them to apps/web/.env as well.

# NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
# NEXT_PUBLIC_NAME_SERVICE_ADDRESS=0x...
